# Server
PORT=4001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# OpenAI (planner)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_APP_ID=far-away-assistant

# Google OAuth / Service Account
# Use service account JSON path OR inline credentials for Sheets/Gmail/Calendar
GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PROJECT_ID=

# Default Google resources
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_CALENDAR_ID=primary
GMAIL_SENDER_EMAIL=

# Mock mode — run tools without real Google API calls (useful for local dev)
GOOGLE_MOCK_MODE=true
